---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import { getToolFeatureImage } from '../../lib/feature-images';

interface ToolLinks {
  open?: string;
  code?: string;
}

interface ToolCardProps {
  title: string;
  summary: string;
  status: string;
  detailHref: string;
  links?: ToolLinks;
  tags?: string[];
  featured?: boolean;
  featureImage?: string;
}

const {
  title,
  summary,
  status,
  detailHref,
  links = {},
  tags = [],
  featured = false,
  featureImage,
} = Astro.props as ToolCardProps;

const actions = [
  { label: 'Read tool notes', href: detailHref },
  { label: 'Open tool', href: links.open },
  { label: 'View code', href: links.code },
]
  .filter((action): action is { label: string; href: string } => Boolean(action.href))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
const primaryTags = tags.slice(0, 2);
const visibleTags = tags.slice(primaryTags.length);
---

<Card
  variant={featured ? 'soft' : 'default'}
  interactive={true}
  class="tool-card"
>
  <div slot="title" class="tool-card__title">
    <p class="tool-card__eyebrow">
      <span>Tool</span>
      {primaryTags.length > 0 && <span>{primaryTags.join(' / ')}</span>}
    </p>
    <div class="tool-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">Featured</Tag>}
    </div>
    <h3>
      <a class="tool-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="tool-card__preview">
    <img src={getToolFeatureImage(featureImage)} alt={`${title} preview`} loading="lazy" />
  </div>

  <p class="tool-card__summary">{summary}</p>

  {visibleTags.length > 0 && (
    <div class="tool-card__tags" aria-label={`${title} tags`}>
      {visibleTags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  <div slot="actions">
    {actions.map((action, index) => (
      <Button
        variant={index === 0 ? 'primary' : 'secondary'}
        href={action.href}
        target={action.isExternal ? '_blank' : undefined}
        rel={action.isExternal ? 'noreferrer' : undefined}
      >
        {action.label}
      </Button>
      ))}
  </div>
</Card>
