---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import {
  getToolFeatureImage,
  hasToolFeatureImage,
} from '../../lib/feature-images';

interface ToolLinks {
  open?: string;
  code?: string;
}

interface ToolCardProps {
  title: string;
  summary: string;
  cardEyebrowDetail?: string;
  featuredLabel?: string;
  status: string;
  detailHref: string;
  links?: ToolLinks;
  tags?: string[];
  featured?: boolean;
  featureImage?: string;
  showPreview?: boolean;
  primaryActionLabel?: string;
  openActionLabel?: string;
  codeActionLabel?: string;
}

const {
  title,
  summary,
  cardEyebrowDetail,
  featuredLabel = 'Featured',
  status,
  detailHref,
  links = {},
  tags = [],
  featured = false,
  featureImage,
  showPreview = true,
  primaryActionLabel = 'Read tool blog',
  openActionLabel = 'Use tool',
  codeActionLabel = 'Review code',
} = Astro.props as ToolCardProps;

const resolvedFeatureImage = getToolFeatureImage(featureImage);
const shouldShowPreview = showPreview && hasToolFeatureImage(resolvedFeatureImage);
const actions = [
  { label: primaryActionLabel, href: detailHref },
  { label: openActionLabel, href: links.open },
  { label: codeActionLabel, href: links.code },
]
  .filter((action): action is { label: string; href: string } => Boolean(action.href))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
const eyebrowDetail = cardEyebrowDetail ?? tags.slice(0, 2).join(' / ');
const visibleTags = cardEyebrowDetail ? tags : tags.slice(2);
---

<Card
  variant={featured ? 'soft' : 'default'}
  interactive={true}
  class="tool-card"
>
  <div slot="title" class="tool-card__title">
    <p class="tool-card__eyebrow">
      <span>Tool</span>
      {eyebrowDetail && <span>{eyebrowDetail}</span>}
    </p>
    <div class="tool-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">{featuredLabel}</Tag>}
    </div>
    <h3>
      <a class="tool-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  {shouldShowPreview && (
    <div class="tool-card__preview">
      <img src={resolvedFeatureImage} alt={`${title} preview`} loading="lazy" />
    </div>
  )}

  <p class="tool-card__summary">{summary}</p>

  {visibleTags.length > 0 && (
    <div class="tool-card__tags" aria-label={`${title} tags`}>
      {visibleTags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  <div slot="actions">
    {actions.map((action, index) => (
      <Button
        variant={index === 0 ? 'primary' : 'secondary'}
        href={action.href}
        target={action.isExternal ? '_blank' : undefined}
        rel={action.isExternal ? 'noreferrer' : undefined}
      >
        {action.label}
      </Button>
      ))}
  </div>
</Card>
