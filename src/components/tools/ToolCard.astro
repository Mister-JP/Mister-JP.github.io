---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import { getToolFeatureImage } from '../../lib/feature-images';

interface ToolLinks {
  open?: string;
  code?: string;
}

interface ToolCardProps {
  title: string;
  summary: string;
  status: string;
  detailHref: string;
  links?: ToolLinks;
  tags?: string[];
  featured?: boolean;
  featureImage?: string;
}

const {
  title,
  summary,
  status,
  detailHref,
  links = {},
  tags = [],
  featured = false,
  featureImage,
} = Astro.props as ToolCardProps;

const actions = [
  { label: 'Details', href: detailHref },
  { label: 'Open', href: links.open },
  { label: 'Code', href: links.code },
]
  .filter((action): action is { label: string; href: string } => Boolean(action.href))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
---

<Card
  variant={featured ? 'soft' : 'default'}
  interactive={true}
  class="tool-card"
>
  <div slot="title" class="tool-card__title">
    <div class="tool-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">Featured</Tag>}
    </div>
    <h3>
      <a class="tool-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="tool-card__preview">
    <img src={getToolFeatureImage(featureImage)} alt={`${title} preview`} loading="lazy" />
  </div>

  <p>{summary}</p>

  {tags.length > 0 && (
    <div class="tool-card__tags" aria-label={`${title} tags`}>
      {tags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  <div slot="actions">
    {actions.map((action, index) => (
      <Button
        variant={index === 0 ? 'primary' : 'secondary'}
        href={action.href}
        target={action.isExternal ? '_blank' : undefined}
        rel={action.isExternal ? 'noreferrer' : undefined}
      >
        {action.label}
      </Button>
    ))}
  </div>
</Card>

<style>
  .tool-card {
    height: 100%;
  }

  .tool-card__title {
    display: grid;
    gap: var(--space-3);
  }

  .tool-card__meta,
  .tool-card__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .tool-card__preview {
    min-height: 11rem;
    border: var(--border-thin);
    border-radius: var(--radius-md);
    background: var(--surface-preview);
    overflow: hidden;
  }

  .tool-card__preview img {
    display: block;
    width: 100%;
    min-height: 11rem;
  }

  .tool-card__preview img {
    object-fit: cover;
  }

  .tool-card h3,
  .tool-card p {
    margin: 0;
  }

  .tool-card p {
    line-height: var(--line-relaxed);
  }
</style>
