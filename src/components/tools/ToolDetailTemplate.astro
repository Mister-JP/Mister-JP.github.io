---
import Card from '../ui/Card.astro';
import Container from '../ui/Container.astro';
import FeatureMedia from '../ui/FeatureMedia.astro';
import Prose from '../ui/Prose.astro';
import Section from '../ui/Section.astro';
import Tag from '../ui/Tag.astro';
import PageHeader from '../layout/PageHeader.astro';
import { hasToolFeatureImage } from '../../lib/feature-images';

interface DetailLink {
  label: string;
  href: string;
  isExternal?: boolean;
}

interface HeadingLink {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedProjectLink {
  title: string;
  summary: string;
  status: string;
  href: string;
}

interface RelatedWritingItem {
  title: string;
  summary: string;
  status: string;
  categoryLabel: string;
  href: string;
  tags?: string[];
}

interface ToolDetailTemplateProps {
  title: string;
  summary: string;
  status: string;
  tags?: string[];
  featureImage: string;
  links?: DetailLink[];
  relatedProjects?: RelatedProjectLink[];
  relatedWriting?: RelatedWritingItem[];
  headings?: HeadingLink[];
}

const {
  title,
  summary,
  status,
  tags = [],
  featureImage,
  links = [],
  relatedProjects = [],
  relatedWriting = [],
  headings = [],
} = Astro.props as ToolDetailTemplateProps;

const hasBody = Astro.slots.has('default');
const outline = headings.filter((heading) => heading.depth <= 2);
const hasGuide =
  links.length > 0 ||
  relatedProjects.length > 0 ||
  relatedWriting.length > 0 ||
  outline.length > 0;
---

<PageHeader eyebrow="Tool" title={title} description={summary}>
  <Tag slot="meta" tone="accent">{status}</Tag>
  {tags.map((tag) => (
    <Tag slot="meta" tone="muted">{tag}</Tag>
  ))}
</PageHeader>

<Section size="sm">
  <Container size="wide">
    <div class="tool-detail-template">
      {hasToolFeatureImage(featureImage) && (
        <FeatureMedia src={featureImage} alt={`${title} preview`} />
      )}

      {hasGuide && (
        <section class="tool-detail-template__guide" aria-label="Tool guide">
          <Card>
            <div class="tool-detail-template__guide-list">
              {links.length > 0 && (
                <section class="tool-detail-template__guide-item" aria-labelledby="tool-links">
                  <h2 id="tool-links" class="tool-detail-template__card-title">Quick links</h2>
                  <div class="tool-detail-template__links">
                    {links.map((link) => (
                      <a
                        class="text-link"
                        href={link.href}
                        target={link.isExternal ? '_blank' : undefined}
                        rel={link.isExternal ? 'noreferrer' : undefined}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </section>
              )}

              {relatedProjects.length > 0 && (
                <section class="tool-detail-template__guide-item" aria-labelledby="tool-related-project">
                  <h2 id="tool-related-project" class="tool-detail-template__card-title">
                    {relatedProjects.length === 1 ? 'Related Project' : 'Related Projects'}
                  </h2>

                  <ul class="tool-detail-template__related-list">
                    {relatedProjects.map((project) => (
                      <li>
                        <Card variant="soft" class="tool-detail-template__related-card">
                          <div class="tool-detail-template__related-meta">
                            <Tag tone="accent">Project</Tag>
                            <Tag tone="muted">{project.status}</Tag>
                          </div>
                          <h3 class="tool-detail-template__card-subtitle">
                            <a class="text-link" href={project.href}>{project.title}</a>
                          </h3>
                          <p>{project.summary}</p>
                        </Card>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {relatedWriting.length > 0 && (
                <section class="tool-detail-template__guide-item" aria-labelledby="tool-related-writing">
                  <h2 id="tool-related-writing" class="tool-detail-template__card-title">
                    Related Writing
                  </h2>

                  <ul class="tool-detail-template__related-list">
                    {relatedWriting.map((entry) => (
                      <li>
                        <Card variant="soft" class="tool-detail-template__related-card">
                          <div class="tool-detail-template__related-meta">
                            <Tag tone="accent">{entry.categoryLabel}</Tag>
                            <Tag tone="muted">{entry.status}</Tag>
                          </div>

                          <h3 class="tool-detail-template__card-subtitle">
                            <a class="text-link" href={entry.href}>{entry.title}</a>
                          </h3>

                          <p>{entry.summary}</p>

                          {entry.tags && entry.tags.length > 0 && (
                            <div class="tool-detail-template__tag-strip" aria-label={`${entry.title} tags`}>
                              {entry.tags.map((tag) => (
                                <Tag tone="muted">{tag}</Tag>
                              ))}
                            </div>
                          )}
                        </Card>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {outline.length > 0 && (
                <section class="tool-detail-template__guide-item" aria-labelledby="tool-outline">
                  <h2 id="tool-outline" class="tool-detail-template__card-title">
                    On this page
                  </h2>

                  <ol class="tool-detail-template__outline">
                    {outline.map((heading) => (
                      <li>
                        <a class="text-link" href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ol>
                </section>
              )}
            </div>
          </Card>
        </section>
      )}

      {hasBody ? (
        <article class="tool-detail-template__body">
          <Prose class="tool-detail-template__prose">
            <slot />
          </Prose>
        </article>
      ) : (
        <p class="tool-detail-template__empty">Notes will arrive here as the tool settles.</p>
      )}
    </div>
  </Container>
</Section>
