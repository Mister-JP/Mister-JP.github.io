---
import Card from '../ui/Card.astro';
import Container from '../ui/Container.astro';
import FeatureMedia from '../ui/FeatureMedia.astro';
import Prose from '../ui/Prose.astro';
import Section from '../ui/Section.astro';
import Tag from '../ui/Tag.astro';
import PageHeader from '../layout/PageHeader.astro';

type WritingKind = 'case-study' | 'method';

interface HeadingLink {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedProjectLink {
  title: string;
  summary: string;
  status: string;
  href: string;
}

interface WritingDetailTemplateProps {
  title: string;
  summary: string;
  featureImage: string;
  kind: WritingKind;
  status: string;
  tags?: string[];
  relatedProjects?: RelatedProjectLink[];
  headings?: HeadingLink[];
}

const {
  title,
  summary,
  featureImage,
  kind,
  status,
  tags = [],
  relatedProjects = [],
  headings = [],
} = Astro.props as WritingDetailTemplateProps;

const hasBody = Astro.slots.has('default');
const kindLabel = kind === 'case-study' ? 'Case Study' : 'Method';
const outline = headings.filter((heading) => heading.depth <= 2);
const hasGuide = outline.length > 0 || relatedProjects.length > 0;
---

<PageHeader eyebrow="Writing" title={title} description={summary}>
  <Tag slot="meta" tone="muted">{kindLabel}</Tag>
  <Tag slot="meta" tone="accent">{status}</Tag>
  {tags.map((tag) => (
    <Tag slot="meta" tone="muted">{tag}</Tag>
  ))}
</PageHeader>

<Section size="sm">
  <Container size="narrow">
    <div class="writing-detail-template">
      <FeatureMedia src={featureImage} alt={`${title} preview`} />

      {hasGuide && (
        <section class="writing-detail-template__guide" aria-label="Writing guide">
          <Card>
            <div class="writing-detail-template__guide-list">
              {relatedProjects.length > 0 && (
                <section
                  class="writing-detail-template__guide-item"
                  aria-labelledby="writing-related-project"
                >
                  <h2 id="writing-related-project" class="writing-detail-template__card-title">
                    {relatedProjects.length === 1 ? 'Related Project' : 'Related Projects'}
                  </h2>

                  <ul class="writing-detail-template__related-list">
                    {relatedProjects.map((project) => (
                      <li>
                        <Card variant="soft" class="writing-detail-template__related-card">
                          <div class="writing-detail-template__related-meta">
                            <Tag tone="accent">Project</Tag>
                            <Tag tone="muted">{project.status}</Tag>
                          </div>
                          <h3 class="writing-detail-template__card-subtitle">
                            <a class="text-link" href={project.href}>{project.title}</a>
                          </h3>
                          <p>{project.summary}</p>
                        </Card>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {outline.length > 0 && (
                <section class="writing-detail-template__guide-item" aria-labelledby="writing-outline">
                  <h2 id="writing-outline" class="writing-detail-template__card-title">
                    Section Outline
                  </h2>

                  <ol class="writing-detail-template__outline">
                    {outline.map((heading) => (
                      <li>
                        <a class="text-link" href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ol>
                </section>
              )}
            </div>
          </Card>
        </section>
      )}

      {hasBody ? (
        <article class="writing-detail-template__body">
          <Prose class="writing-detail-template__prose">
            <slot />
          </Prose>
        </article>
      ) : (
        <p class="writing-detail-template__empty">No content yet.</p>
      )}
    </div>
  </Container>
</Section>

<style>
  .writing-detail-template {
    display: grid;
    gap: var(--space-6);
  }

  .writing-detail-template__prose {
    max-width: none;
  }

  .writing-detail-template__guide-list,
  .writing-detail-template__guide-item,
  .writing-detail-template__related-card {
    display: grid;
    gap: var(--space-3);
  }

  .writing-detail-template__guide-item + .writing-detail-template__guide-item {
    padding-top: var(--space-4);
    border-top: var(--border-thin);
  }

  .writing-detail-template__card-title,
  .writing-detail-template__card-subtitle {
    margin: 0;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    line-height: var(--line-tight);
  }

  .writing-detail-template__card-subtitle {
    font-size: 0.98rem;
  }

  .writing-detail-template__related-card {
    --card-padding: var(--space-4);
    gap: var(--space-3);
    box-shadow: none;
  }

  .writing-detail-template__related-card p,
  .writing-detail-template__empty {
    margin: 0;
    line-height: var(--line-relaxed);
    color: var(--color-text-secondary);
  }

  .writing-detail-template__related-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .writing-detail-template__outline {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding-left: 1.1rem;
  }

  .writing-detail-template__related-list {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
</style>
