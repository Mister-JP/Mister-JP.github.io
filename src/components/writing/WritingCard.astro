---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import {
  getWritingFeatureImage,
  hasWritingFeatureImage,
} from '../../lib/feature-images';
import type { WritingCategory } from '../../lib/writing-categories';
import { getWritingCategoryMeta } from '../../lib/writing-categories';

interface RelatedProjectLink {
  href?: string;
  title: string;
}

interface WritingCardProps {
  title: string;
  summary: string;
  featureImage?: string;
  category: WritingCategory;
  cardLabel?: string;
  cardCtaLabel?: string;
  in_draft?: boolean;
  tags?: string[];
  featured?: boolean;
  compact?: boolean;
  href: string;
  relatedProjects?: RelatedProjectLink[];
}

const {
  title,
  summary,
  featureImage,
  category,
  cardLabel,
  cardCtaLabel,
  in_draft = false,
  tags = [],
  featured = false,
  compact = false,
  href,
  relatedProjects = [],
} = Astro.props as WritingCardProps;

const categoryMeta = getWritingCategoryMeta(category);
const visibleCardLabel = cardLabel ?? categoryMeta.label;
const visibleCtaLabel = cardCtaLabel ?? categoryMeta.ctaLabel;
const resolvedFeatureImage = getWritingFeatureImage(featureImage);
const shouldShowPreview = !compact && hasWritingFeatureImage(resolvedFeatureImage);
---

<Card
  variant={featured ? 'soft' : compact ? 'neutral' : 'default'}
  interactive={true}
  class="writing-card"
>
  <div slot="title" class="writing-card__title">
    <div class="writing-card__meta">
      <Tag tone={categoryMeta.tagTone}>{visibleCardLabel}</Tag>
      {in_draft && <Tag tone="muted">In progress</Tag>}
      {featured && <Tag tone="accent">Featured</Tag>}
    </div>
    <h3>
      <a class="writing-card__title-link text-link" href={href}>{title}</a>
    </h3>
  </div>

  {shouldShowPreview && (
    <div class="writing-card__preview">
      <img src={resolvedFeatureImage} alt={`${title} preview`} loading="lazy" />
    </div>
  )}

  <p class="writing-card__summary">{summary}</p>

  {relatedProjects.length > 0 && (
    <p class="writing-card__related">
      {relatedProjects.length === 1 ? 'Related project: ' : 'Related projects: '}
      {relatedProjects.map((project, index) => (
        <span>
          {index > 0 && <span>, </span>}
          {project.href ? (
            <a class="text-link" href={project.href}>{project.title}</a>
          ) : (
            <span>{project.title}</span>
          )}
        </span>
      ))}
    </p>
  )}

  {tags.length > 0 && (
    <div class="writing-card__tags" aria-label={`${title} tags`}>
      {tags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  {!compact && (
    <div slot="actions">
      <Button href={href}>{visibleCtaLabel}</Button>
    </div>
  )}
</Card>
