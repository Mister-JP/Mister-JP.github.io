---
import type { ResolvedNavItem } from '../../data/navigation';

const { items = [] } = Astro.props as {
  items?: ResolvedNavItem[];
};
---

<div class="mobile-nav">
  <ul class="mobile-nav__list">
    {items.map((item) => (
      <li>
        <a
          class:list={[
            'mobile-nav__link',
            item.href === '/resume' && 'mobile-nav__link--resume',
          ]}
          href={item.href}
          aria-current={item.isCurrent ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</div>
