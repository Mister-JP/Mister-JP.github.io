---
import Container from '../ui/Container.astro';

interface PageHeaderProps {
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  class: className = '',
} = Astro.props as PageHeaderProps;

const hasMeta = Astro.slots.has('meta');
const hasBody = Astro.slots.has('default');
---

<header class:list={['page-header', className]}>
  <Container size="narrow" class="page-header__inner">
    {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
    {title && <h1 class="page-header__title">{title}</h1>}
    {description && <p class="page-header__description">{description}</p>}
    {hasBody && <div class="page-header__body"><slot /></div>}
    {hasMeta && <div class="page-header__meta"><slot name="meta" /></div>}
  </Container>
</header>
