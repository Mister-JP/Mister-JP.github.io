---
type ContainerTag = 'div' | 'section' | 'article' | 'header' | 'main';
type ContainerSize = 'default' | 'narrow' | 'wide';

interface ContainerProps {
  as?: ContainerTag;
  size?: ContainerSize;
  class?: string;
  [key: string]: unknown;
}

const {
  as: Tag = 'div',
  size = 'default',
  class: className = '',
  ...rest
} = Astro.props as ContainerProps;
---

<Tag class:list={['container', `container--${size}`, className]} {...rest}>
  <slot />
</Tag>
