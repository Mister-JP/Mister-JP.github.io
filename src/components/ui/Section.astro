---
type SectionTag = 'section' | 'div' | 'article' | 'header';
type SectionSize = 'sm' | 'md' | 'lg';
type SectionTone = 'default' | 'soft' | 'muted';

interface SectionProps {
  as?: SectionTag;
  size?: SectionSize;
  tone?: SectionTone;
  class?: string;
  [key: string]: unknown;
}

const {
  as: Tag = 'section',
  size = 'md',
  tone = 'default',
  class: className = '',
  ...rest
} = Astro.props as SectionProps;
---

<Tag class:list={['section', `section--${size}`, `section--${tone}`, className]} {...rest}>
  <slot />
</Tag>

<style>
  .section {
    --section-space: var(--section-space-md);
    padding-block: var(--section-space);
  }

  .section--sm {
    --section-space: var(--section-space-sm);
  }

  .section--lg {
    --section-space: var(--section-space-lg);
  }

  .section--soft {
    background: var(--surface-section-soft);
    border-block: var(--border-thin);
  }

  .section--muted {
    background: var(--surface-section-muted);
    border-block: var(--border-thin);
  }
</style>
