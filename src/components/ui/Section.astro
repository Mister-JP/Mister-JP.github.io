---
type SectionTag = 'section' | 'div' | 'article' | 'header';
type SectionSize = 'sm' | 'md' | 'lg';
type SectionTone = 'default' | 'soft' | 'muted';

interface SectionProps {
  as?: SectionTag;
  size?: SectionSize;
  tone?: SectionTone;
  class?: string;
  [key: string]: unknown;
}

const {
  as: Tag = 'section',
  size = 'md',
  tone = 'default',
  class: className = '',
  ...rest
} = Astro.props as SectionProps;
---

<Tag class:list={['section', `section--${size}`, `section--${tone}`, className]} {...rest}>
  <slot />
</Tag>
