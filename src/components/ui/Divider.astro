---
type DividerSpace = 'sm' | 'md' | 'lg';

interface DividerProps {
  space?: DividerSpace;
  class?: string;
}

const {
  space = 'md',
  class: className = '',
} = Astro.props as DividerProps;

const hasLabel = Astro.slots.has('default');
---

<div class:list={['divider', `divider--${space}`, className]} role="presentation">
  <span class="divider__line"></span>
  {hasLabel && <span class="divider__label"><slot /></span>}
  <span class="divider__line"></span>
</div>
