---
type CardVariant = 'default' | 'soft' | 'muted' | 'accent' | 'neutral';
type CardTag = 'article' | 'section' | 'div';

interface CardProps {
  href?: string;
  as?: CardTag;
  variant?: CardVariant;
  interactive?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  as = 'article',
  variant = 'default',
  interactive = typeof href === 'string' && href.length > 0,
  class: className = '',
  ...rest
} = Astro.props as CardProps;

const Tag = href ? 'a' : as;
const hasTitle = Astro.slots.has('title');
const hasActions = Astro.slots.has('actions');
---

<Tag
  class:list={[
    'card',
    `card--${variant}`,
    interactive && 'card--interactive',
    className,
  ]}
  href={href}
  {...rest}
>
  {hasTitle && (
    <div class="card__head">
      <slot name="title" />
    </div>
  )}
  <div class="card__body">
    <slot />
  </div>
  {hasActions && (
    <div class="card__actions">
      <slot name="actions" />
    </div>
  )}
</Tag>

<style>
  .card {
    --card-background: var(--surface-panel);
    --card-border: var(--border-thin);
    --card-shadow: var(--shadow-soft);
    display: grid;
    gap: var(--space-4);
    height: 100%;
    padding: var(--card-padding);
    border: var(--card-border);
    border-radius: var(--radius-lg);
    background: var(--card-background);
    box-shadow: var(--card-shadow);
    color: inherit;
    text-decoration: none;
    transition:
      transform var(--transition-soft),
      box-shadow var(--transition-base),
      border-color var(--transition-soft);
  }

  .card--soft {
    --card-background: var(--surface-panel-soft);
  }

  .card--muted {
    --card-background: var(--surface-panel-muted);
  }

  .card--accent {
    --card-background: var(--surface-panel-accent);
    --card-border: var(--border-accent);
    --card-shadow: var(--shadow-raised);
  }

  .card--neutral {
    --card-background: var(--surface-panel-neutral);
    --card-shadow: none;
  }

  .card--interactive:hover,
  .card--interactive:focus-within,
  .card--interactive:focus-visible {
    transform: translateY(var(--motion-lift-md));
    box-shadow: var(--shadow-lift);
    border-color: var(--color-border-strong);
  }

  .card__head {
    display: grid;
    gap: var(--space-2);
  }

  .card__body {
    display: grid;
    gap: var(--space-4);
    align-content: start;
    color: var(--color-text-secondary);
  }

  .card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: auto;
  }
</style>
