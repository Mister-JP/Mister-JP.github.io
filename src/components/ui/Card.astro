---
type CardVariant = 'default' | 'soft' | 'muted' | 'accent' | 'neutral';
type CardTag = 'article' | 'section' | 'div';

interface CardProps {
  href?: string;
  as?: CardTag;
  variant?: CardVariant;
  interactive?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  as = 'article',
  variant = 'default',
  interactive = typeof href === 'string' && href.length > 0,
  class: className = '',
  ...rest
} = Astro.props as CardProps;

const Tag = href ? 'a' : as;
const hasTitle = Astro.slots.has('title');
const hasActions = Astro.slots.has('actions');
---

<Tag
  class:list={[
    'card',
    `card--${variant}`,
    interactive && 'card--interactive',
    className,
  ]}
  href={href}
  {...rest}
>
  {hasTitle && (
    <div class="card__head">
      <slot name="title" />
    </div>
  )}
  <div class="card__body">
    <slot />
  </div>
  {hasActions && (
    <div class="card__actions">
      <slot name="actions" />
    </div>
  )}
</Tag>
