---
type TagTone = 'default' | 'accent' | 'muted';
type TagElement = 'span' | 'button';

interface TagProps {
  tone?: TagTone;
  as?: TagElement;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  tone = 'default',
  as = 'span',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props as TagProps;

const TagName = as;
---

<TagName
  class:list={['tag', `tag--${tone}`, className]}
  type={TagName === 'button' ? type : undefined}
  {...rest}
>
  <slot />
</TagName>
