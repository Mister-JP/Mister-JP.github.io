---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';

interface ProjectLinkAction {
  label: string;
  href: string;
  isExternal?: boolean;
}

const {
  actions = [],
} = Astro.props as {
  actions?: ProjectLinkAction[];
};

const sectionId = 'project-links';
---

<section class="project-links-section" aria-labelledby={sectionId}>
  <Card>
    <div slot="title" class="project-links-section__head">
      <h2 id={sectionId}>Links</h2>
      <p>Keep the immediate next actions visible here when there is code, a case study, or a demo to inspect.</p>
    </div>

    {actions.length > 0 ? (
      <div class="project-links-section__actions">
        {actions.map((action, index) => (
          <Button
            variant={index === 0 ? 'primary' : 'secondary'}
            href={action.href}
            target={action.isExternal ? '_blank' : undefined}
            rel={action.isExternal ? 'noreferrer' : undefined}
          >
            {action.label}
          </Button>
        ))}
      </div>
    ) : (
      <p class="project-links-section__empty">Project links coming soon.</p>
    )}
  </Card>
</section>
