---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import { getProjectHref } from '../../lib/content-paths';
import { getProjectFeatureImage } from '../../lib/feature-images';

interface ProjectLinks {
  code?: string;
  demo?: string;
}

interface ProjectCardProps {
  slug: string;
  title: string;
  summary: string;
  status: string;
  currentMilestone?: string;
  tags: string[];
  links: ProjectLinks;
  featureImage?: string;
  featured?: boolean;
  emphasis?: 'default' | 'lead';
  class?: string;
  [key: string]: unknown;
}

const {
  slug,
  title,
  summary,
  status,
  currentMilestone,
  tags = [],
  links = {},
  featureImage,
  featured = false,
  emphasis = 'default',
  class: className = '',
  ...rest
} = Astro.props as ProjectCardProps;

const detailHref = getProjectHref({ slug });
const actions = [
  { label: 'View project', href: detailHref },
  links.code ? { label: 'View code', href: links.code } : undefined,
  links.demo ? { label: 'Open demo', href: links.demo } : undefined,
]
  .filter((action): action is { label: string; href: string } => Boolean(action))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
const cardVariant = emphasis === 'lead' ? 'accent' : featured ? 'soft' : 'default';
const primaryTags = tags.slice(0, 2);
const visibleTags = tags.slice(primaryTags.length);
---

<Card
  variant={cardVariant}
  interactive={true}
  class:list={['project-card', emphasis === 'lead' && 'project-card--lead', className]}
  {...rest}
>
  <div slot="title" class="project-card__title">
    <p class="project-card__eyebrow">
      <span>Project</span>
      {primaryTags.length > 0 && <span>{primaryTags.join(' / ')}</span>}
    </p>
    <div class="project-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">Featured</Tag>}
    </div>
    <h3>
      <a class="project-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="project-card__preview">
    <img src={getProjectFeatureImage(featureImage)} alt={`${title} preview`} loading="lazy" />
  </div>

  <p class="project-card__summary">{summary}</p>

  {currentMilestone && (
    <p class="project-card__focus">
      <span class="project-card__focus-label">Current focus</span>
      <span>{currentMilestone}</span>
    </p>
  )}

  {visibleTags.length > 0 && (
    <div class="project-card__tags" aria-label={`${title} tags`}>
      {visibleTags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  {actions.length > 0 && (
    <div slot="actions">
      {actions.map((action, index) => (
        <Button
          variant={index === 0 ? 'primary' : 'secondary'}
          href={action.href}
          target={action.isExternal ? '_blank' : undefined}
          rel={action.isExternal ? 'noreferrer' : undefined}
        >
          {action.label}
        </Button>
      ))}
    </div>
  )}
</Card>
