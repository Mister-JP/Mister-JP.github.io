---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import { getProjectHref } from '../../lib/content-paths';
import { getProjectFeatureImage } from '../../lib/feature-images';
import { toTagFilterValue } from '../../lib/tag-filters';

interface ProjectLinks {
  code?: string;
  demo?: string;
}

interface ProjectCardProps {
  slug: string;
  title: string;
  summary: string;
  status: string;
  tags: string[];
  links: ProjectLinks;
  featureImage?: string;
  featured?: boolean;
  filterableTags?: boolean;
}

const {
  slug,
  title,
  summary,
  status,
  tags = [],
  links = {},
  featureImage,
  featured = false,
  filterableTags = false,
} = Astro.props as ProjectCardProps;

const detailHref = getProjectHref({ slug });
const tagFilters = tags.map((tag) => ({
  label: tag,
  value: toTagFilterValue(tag),
}));
const actions = [
  { label: 'View project', href: detailHref },
  links.code ? { label: 'Code', href: links.code } : undefined,
  links.demo ? { label: 'Demo', href: links.demo } : undefined,
]
  .filter((action): action is { label: string; href: string } => Boolean(action))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
---

<Card
  variant={featured ? 'soft' : 'default'}
  interactive={true}
  class="project-card"
  data-project-card
  data-project-tags={tagFilters.map(({ value }) => value).join(' ')}
>
  <div slot="title" class="project-card__title">
    <div class="project-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">Featured</Tag>}
    </div>
    <h3>
      <a class="project-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  <div class="project-card__preview">
    <img src={getProjectFeatureImage(featureImage)} alt={`${title} preview`} loading="lazy" />
  </div>

  <p>{summary}</p>

  <div class="project-card__tags" aria-label={`${title} tags`}>
    {tagFilters.map(({ label, value }) => (
      filterableTags ? (
        <Tag
          as="button"
          tone="muted"
          data-project-filter={value}
          data-chip-removable="true"
          aria-pressed="false"
          aria-label={`Toggle project filter ${label}`}
        >
          {label}
        </Tag>
      ) : (
        <Tag tone="muted">{label}</Tag>
      )
    ))}
  </div>

  {actions.length > 0 && (
    <div slot="actions">
      {actions.map((action, index) => (
        <Button
          variant={index === 0 ? 'primary' : 'secondary'}
          href={action.href}
          target={action.isExternal ? '_blank' : undefined}
          rel={action.isExternal ? 'noreferrer' : undefined}
        >
          {action.label}
        </Button>
      ))}
    </div>
  )}
</Card>
