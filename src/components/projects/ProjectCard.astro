---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import { getProjectHref } from '../../lib/content-paths';
import {
  getProjectFeatureImage,
  hasProjectFeatureImage,
} from '../../lib/feature-images';

interface ProjectLinks {
  code?: string;
  demo?: string;
}

interface ProjectCardProps {
  slug: string;
  title: string;
  summary: string;
  cardEyebrowDetail?: string;
  featuredLabel?: string;
  whyItMatters: string;
  status: string;
  currentMilestone?: string;
  tags: string[];
  links: ProjectLinks;
  featureImage?: string;
  featured?: boolean;
  emphasis?: 'default' | 'lead';
  showPreview?: boolean;
  primaryActionLabel?: string;
  codeActionLabel?: string;
  demoActionLabel?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  slug,
  title,
  summary,
  cardEyebrowDetail,
  featuredLabel = 'Featured',
  whyItMatters,
  status,
  currentMilestone,
  tags = [],
  links = {},
  featureImage,
  featured = false,
  emphasis = 'default',
  showPreview = true,
  primaryActionLabel = 'Inspect project brief',
  codeActionLabel = 'Review code',
  demoActionLabel = 'Open live demo',
  class: className = '',
  ...rest
} = Astro.props as ProjectCardProps;

const detailHref = getProjectHref({ slug });
const resolvedFeatureImage = getProjectFeatureImage(featureImage);
const shouldShowPreview = showPreview && hasProjectFeatureImage(resolvedFeatureImage);
const actions = [
  { label: primaryActionLabel, href: detailHref },
  links.code ? { label: codeActionLabel, href: links.code } : undefined,
  links.demo ? { label: demoActionLabel, href: links.demo } : undefined,
]
  .filter((action): action is { label: string; href: string } => Boolean(action))
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
const cardVariant = emphasis === 'lead' ? 'accent' : featured ? 'soft' : 'default';
const eyebrowDetail = cardEyebrowDetail ?? tags.slice(0, 2).join(' / ');
const visibleTags = cardEyebrowDetail ? tags : tags.slice(2);
---

<Card
  variant={cardVariant}
  interactive={true}
  class:list={['project-card', emphasis === 'lead' && 'project-card--lead', className]}
  {...rest}
>
  <div slot="title" class="project-card__title">
    <p class="project-card__eyebrow">
      <span>Project</span>
      {eyebrowDetail && <span>{eyebrowDetail}</span>}
    </p>
    <div class="project-card__meta">
      <Tag tone={featured ? 'accent' : 'default'}>{status}</Tag>
      {featured && <Tag tone="muted">{featuredLabel}</Tag>}
    </div>
    <h3>
      <a class="project-card__title-link text-link" href={detailHref}>{title}</a>
    </h3>
  </div>

  {shouldShowPreview && (
    <div class="project-card__preview">
      <img src={resolvedFeatureImage} alt={`${title} preview`} loading="lazy" />
    </div>
  )}

  <p class="project-card__summary">{summary}</p>

  <p class="project-card__evidence">
    <span class="project-card__section-label">Why it matters</span>
    <span>{whyItMatters}</span>
  </p>

  {currentMilestone && (
    <p class="project-card__focus">
      <span class="project-card__section-label">Current checkpoint</span>
      <span>{currentMilestone}</span>
    </p>
  )}

  {visibleTags.length > 0 && (
    <div class="project-card__tags" aria-label={`${title} tags`}>
      {visibleTags.map((tag) => (
        <Tag tone="muted">{tag}</Tag>
      ))}
    </div>
  )}

  {actions.length > 0 && (
    <div slot="actions">
      {actions.map((action, index) => (
        <Button
          variant={index === 0 ? 'primary' : 'secondary'}
          href={action.href}
          target={action.isExternal ? '_blank' : undefined}
          rel={action.isExternal ? 'noreferrer' : undefined}
        >
          {action.label}
        </Button>
      ))}
    </div>
  )}
</Card>
