---
import PageHeader from '../layout/PageHeader.astro';
import Card from '../ui/Card.astro';
import Container from '../ui/Container.astro';
import FeatureMedia from '../ui/FeatureMedia.astro';
import Prose from '../ui/Prose.astro';
import Section from '../ui/Section.astro';
import Tag from '../ui/Tag.astro';
import ProjectRelatedSection from './ProjectRelatedSection.astro';
import { hasProjectFeatureImage } from '../../lib/feature-images';

interface ProjectLinkAction {
  label: string;
  href: string;
  isExternal?: boolean;
}

interface HeadingLink {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedItem {
  title: string;
  summary: string;
  status: string;
  metaLabel?: string;
  href?: string;
  isExternal?: boolean;
  tags?: string[];
}

interface ProjectDetailData {
  title: string;
  summary: string;
  featureImage: string;
  whyItMatters: string;
  status: string;
  currentMilestone: string;
  tags: string[];
  links: ProjectLinkAction[];
  headings?: HeadingLink[];
  relatedWriting: RelatedItem[];
  relatedTools: RelatedItem[];
}

const { project } = Astro.props as { project: ProjectDetailData };

const hasLongFormBody = Astro.slots.has('default');
const hasLinks = project.links.length > 0;
const hasRelatedWriting = project.relatedWriting.length > 0;
const hasRelatedTools = project.relatedTools.length > 0;
const whyItMatters = project.whyItMatters.trim();
const currentMilestone = project.currentMilestone.trim();
const outline = (project.headings ?? []).filter((heading) => heading.depth <= 2);
---

<PageHeader eyebrow="Project" title={project.title} description={project.summary}>
  <Tag slot="meta" tone="accent">{project.status}</Tag>
  {project.tags.map((tag) => (
    <Tag slot="meta" tone="muted">{tag}</Tag>
  ))}
</PageHeader>

<Section size="sm">
  <Container size="wide">
    <div class="project-detail-template">
      {hasProjectFeatureImage(project.featureImage) && (
        <FeatureMedia src={project.featureImage} alt={`${project.title} preview`} />
      )}

      <section class="project-detail-template__summary" aria-label="Project summary">
        <Card>
          <div class="project-detail-template__summary-list">
            <div class="project-detail-template__summary-item">
              <p class="project-detail-template__label">Why it matters</p>
              <p class="project-detail-template__copy">{whyItMatters}</p>
            </div>

            <div class="project-detail-template__summary-item">
              <div class="project-detail-template__label-row">
                <p class="project-detail-template__label">Current milestone</p>
                <Tag tone="accent">{project.status}</Tag>
              </div>
              <p class="project-detail-template__copy">{currentMilestone}</p>
            </div>

            {hasLinks && (
              <div class="project-detail-template__summary-item">
                <p class="project-detail-template__label">Links</p>
                <div class="project-detail-template__links" aria-label="Project links">
                  {project.links.map((action) => (
                    <a
                      class="text-link"
                      href={action.href}
                      target={action.isExternal ? '_blank' : undefined}
                      rel={action.isExternal ? 'noreferrer' : undefined}
                    >
                      {action.label}
                    </a>
                  ))}
                </div>
              </div>
            )}

            {outline.length > 0 && (
              <div class="project-detail-template__summary-item">
                <p class="project-detail-template__label">On this page</p>
                <ol class="project-detail-template__outline">
                  {outline.map((heading) => (
                    <li>
                      <a class="text-link" href={`#${heading.slug}`}>{heading.text}</a>
                    </li>
                  ))}
                </ol>
              </div>
            )}
          </div>
        </Card>
      </section>

      {hasLongFormBody && (
        <article class="project-detail-template__body" aria-label="Project details">
          <Prose>
            <slot />
          </Prose>
        </article>
      )}

      {(hasRelatedWriting || hasRelatedTools) && (
        <div class="project-detail-template__related">
          {hasRelatedWriting && (
            <ProjectRelatedSection title="Related Writing" items={project.relatedWriting} />
          )}

          {hasRelatedTools && (
            <ProjectRelatedSection title="Related Tools" items={project.relatedTools} />
          )}
        </div>
      )}
    </div>
  </Container>
</Section>
