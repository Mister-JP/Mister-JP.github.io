---
import { getCollection, getEntries, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import SiteShell from '../layouts/SiteShell.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Grid from '../components/ui/Grid.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import Tag from '../components/ui/Tag.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ProjectFilterBar from '../components/projects/ProjectFilterBar.astro';
import { shellConfig } from '../data/site';
import { sortBySortOrderThenTitle } from '../lib/collection-utils';
import { toTagFilterValue } from '../lib/tag-filters';

type ProjectEntry = CollectionEntry<'projects'>;
type ProjectCardItem = {
  slug: ProjectEntry['slug'];
  featured?: boolean;
} & ProjectEntry['data'];

const [projectEntries, pageEntry, curationEntry] = await Promise.all([
  getCollection('projects'),
  getEntry('pages', 'projects'),
  getEntry('curation', 'projects'),
]);

const projects: ProjectCardItem[] = projectEntries
  .map(({ data, slug }) => ({ slug, ...data }))
  .sort(sortBySortOrderThenTitle);

const availableTags: string[] = Array.from(
  new Set<string>(projects.flatMap((project): string[] => project.tags)),
).sort((left, right) => left.localeCompare(right));

if (!pageEntry) {
  throw new Error('Missing content entry: src/content/pages/projects.md');
}

if (pageEntry.data.template !== 'projects') {
  throw new Error('The projects page entry must use the "projects" template.');
}

if (!curationEntry) {
  throw new Error('Missing content entry: src/content/curation/projects.md');
}

if (curationEntry.data.surface !== 'projects') {
  throw new Error('The projects curation entry must use the "projects" surface.');
}

const featuredProjects: ProjectCardItem[] = (await getEntries(
  curationEntry.data.featuredProjects,
)).map((entry) => ({
  slug: entry.slug,
  ...entry.data,
  featured: true,
}));

const page = pageEntry.data;
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <PageHeader
    eyebrow={page.eyebrow}
    title={page.title}
    description={page.description}
  >
    <Tag slot="meta" tone="accent">{projects.length} projects</Tag>
    {featuredProjects.length > 0 && (
      <Tag slot="meta" tone="muted">{featuredProjects.length} featured</Tag>
    )}
  </PageHeader>

  {featuredProjects.length > 0 && (
    <Section size="sm" aria-labelledby="featured-projects-title">
      <Container size="wide">
        <SectionIntro
          title={page.featuredSection.title}
          titleId="featured-projects-title"
          description={page.featuredSection.intro}
        />

        <Grid
          cols={featuredProjects.length > 2 ? '3' : 'auto'}
          minItemWidth="18rem"
        >
          {featuredProjects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section tone="soft" aria-labelledby="all-projects-title">
    <Container size="wide">
      <SectionIntro
        title={page.allSection.title}
        titleId="all-projects-title"
        description={page.allSection.intro}
      />

      <div class="projects-catalog" data-project-filter-root>
        {availableTags.length > 0 && <ProjectFilterBar tags={availableTags} />}

        <Grid cols="3">
          {projects.length > 0 ? (
            projects.map((project) => (
              <ProjectCard
                {...project}
                data-project-card="true"
                data-project-tags={project.tags.map((tag) => toTagFilterValue(tag)).join(' ')}
              />
            ))
          ) : (
            <p class="projects-empty">{page.allSection.emptyState}</p>
          )}
        </Grid>
      </div>
    </Container>
  </Section>
</SiteShell>
