---
import SiteShell from '../layouts/SiteShell.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Container from '../components/ui/Container.astro';
import Grid from '../components/ui/Grid.astro';
import Section from '../components/ui/Section.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import GroupedPanel from '../components/ui/GroupedPanel.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ToolCard from '../components/tools/ToolCard.astro';
import WritingCard from '../components/writing/WritingCard.astro';
import { shellConfig } from '../data/site';
import { getHomePageContent } from '../lib/home-content';

const {
  page,
  hero,
  proofStrip,
  intro,
  featuredProjects,
  selectedWriting,
  featuredTools,
} = await getHomePageContent();

const hasFeaturedProjects = featuredProjects.items.length > 0;
const hasIntroLinks = intro.quickLinks.length > 0;
const visibleWritingGroups = selectedWriting.groups
  .map((group, index) => ({
    ...group,
    tone: index === 1 ? 'soft' : 'default',
  }))
  .filter((group) => group.items.length > 0);
const hasSelectedWriting = visibleWritingGroups.length > 0;
const hasFeaturedTools = featuredTools.items.length > 0;
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <Section size="lg" class="home-hero" aria-labelledby="home-hero-title">
    <Container size="wide">
      <div class="home-hero__layout">
        <div class="hero-stack">
          <p class="hero-eyebrow">{hero.eyebrow}</p>
          <h1 id="home-hero-title" class="hero-title">{hero.title}</h1>
          <p class="hero-subtitle">{hero.subtitle}</p>
          <div class="hero-actions">
            <Button href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</Button>
            <Button variant="secondary" href={hero.secondaryCtaHref}>
              {hero.secondaryCtaLabel}
            </Button>
          </div>

          <div class="hero-proof" aria-labelledby="home-proof-title">
            <p id="home-proof-title" class="hero-proof__title">{proofStrip.title}</p>
            <ul class="hero-proof__list">
              {proofStrip.items.map((item) => (
                <li class="hero-proof__item">
                  <span class="hero-proof__label">{item.label}</span>
                  <span class="hero-proof__detail">{item.detail}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <Card
          as="section"
          variant="neutral"
          class="home-orientation"
          aria-labelledby="home-intro-title"
        >
          <div slot="title" class="home-orientation__head">
            <h2 id="home-intro-title">{intro.heading}</h2>
            <p>{intro.body}</p>
          </div>

          <div class="home-orientation__body">
            {hasIntroLinks && (
              <ul class="home-orientation__list">
                {intro.quickLinks.map((link) => (
                  <li class="home-orientation__item">
                    <a class="text-link" href={link.href}>{link.label}</a>
                    <p>{link.description}</p>
                  </li>
                ))}
              </ul>
            )}

            {intro.supportingNote && (
              <p class="home-orientation__note">{intro.supportingNote}</p>
            )}
          </div>
        </Card>
      </div>
    </Container>
  </Section>

  {hasFeaturedProjects && (
    <Section size="sm" aria-labelledby="home-projects-title">
      <Container size="wide">
        <SectionIntro
          title={featuredProjects.sectionTitle}
          titleId="home-projects-title"
          description={featuredProjects.sectionIntro}
          class="home-section-intro"
        />

        <Grid
          cols={featuredProjects.items.length > 2 ? '3' : 'auto'}
          gap="lg"
          minItemWidth="18rem"
        >
          {featuredProjects.items.map((item, index) => (
            <ProjectCard {...item} emphasis={index === 0 ? 'lead' : 'default'} />
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  {hasSelectedWriting && (
    <Section size="sm" tone="muted" aria-labelledby="home-writing-title">
      <Container size="wide">
        <SectionIntro
          title={selectedWriting.sectionTitle}
          titleId="home-writing-title"
          description={selectedWriting.sectionIntro}
          class="home-section-intro"
        />

        <Grid cols={visibleWritingGroups.length > 1 ? '2' : 'auto'} gap="lg">
          {visibleWritingGroups.map((group, index) => (
            <GroupedPanel
              title={group.label}
              titleId={`home-writing-group-${index}`}
              tone={group.tone}
              headingTag="h3"
            >
              <div class="writing-group__list">
                {group.items.map((item) => (
                  <WritingCard {...item} />
                ))}
              </div>
            </GroupedPanel>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  {hasFeaturedTools && (
    <Section size="sm" aria-labelledby="home-tools-title">
      <Container size="wide">
        <SectionIntro
          title={featuredTools.sectionTitle}
          titleId="home-tools-title"
          description={featuredTools.sectionIntro}
          class="home-section-intro"
        />

        <Grid
          cols={featuredTools.items.length === 1 ? '2' : 'auto'}
          gap="lg"
          minItemWidth="18rem"
        >
          {featuredTools.items.map((item) => (
            <ToolCard {...item} />
          ))}
        </Grid>
      </Container>
    </Section>
  )}

</SiteShell>
