---
import SiteShell from '../layouts/SiteShell.astro';
import Button from '../components/ui/Button.astro';
import Container from '../components/ui/Container.astro';
import Grid from '../components/ui/Grid.astro';
import Section from '../components/ui/Section.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import GroupedPanel from '../components/ui/GroupedPanel.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ToolCard from '../components/tools/ToolCard.astro';
import WritingCard from '../components/writing/WritingCard.astro';
import { shellConfig } from '../data/site';
import { getHomePageContent } from '../lib/home-content';
import { getResumePageContent } from '../lib/resume-content';
import { getWritingCategoryMeta } from '../lib/writing-categories';

const [
  {
    page,
    hero,
    proofStrip,
    intro,
    featuredProjects,
    selectedWriting,
    featuredTools,
  },
  resume,
] = await Promise.all([
  getHomePageContent(),
  getResumePageContent(),
]);

const hasFeaturedProjects = featuredProjects.items.length > 0;
const [leadProject, ...supportingProjects] = featuredProjects.items;
const hasSupportingProjects = supportingProjects.length > 0;
const heroProofColumnCount = Math.max(1, proofStrip.items.length);
const visibleWritingGroups = selectedWriting.groups
  .map((group) => ({
    ...group,
    tone: getWritingCategoryMeta(group.category).panelTone,
  }))
  .filter((group) => group.items.length > 0);
const hasSelectedWriting = visibleWritingGroups.length > 0;
const hasFeaturedTools = featuredTools.items.length > 0;
const hasResumeHeading = intro.heading.trim().length > 0;
const resumeSectionLabel = intro.eyebrow ?? 'Resume';
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <Section size="lg" class="home-hero" aria-labelledby="home-hero-title">
    <Container size="wide">
      <div class="home-hero__layout">
        <div class="hero-stack">
          <p class="hero-eyebrow">{hero.eyebrow}</p>
          <div class="hero-main">
            <h1 id="home-hero-title" class="hero-title">{hero.title}</h1>
            <div class="hero-copy">
              <p class="hero-subtitle">{hero.subtitle}</p>

              <div class="hero-actions">
                <Button href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</Button>
                <Button variant="secondary" href={hero.secondaryCtaHref}>
                  {hero.secondaryCtaLabel}
                </Button>
              </div>
            </div>
          </div>

          <div class="hero-proof" aria-labelledby="home-proof-title">
            <p id="home-proof-title" class="hero-proof__title">{proofStrip.title}</p>
            <ul
              class="hero-proof__list"
              style={`--hero-proof-columns: ${heroProofColumnCount};`}
            >
              {proofStrip.items.map((item) => (
                <li class="hero-proof__item">
                  <span class="hero-proof__label">{item.label}</span>
                  <span class="hero-proof__detail">{item.detail}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section size="sm" class="home-resume" aria-label={resumeSectionLabel}>
    <Container size="wide">
      <section class="resume-cta">
        <div class="resume-cta__copy">
          <p class="resume-cta__eyebrow">{resumeSectionLabel}</p>
          {hasResumeHeading && <h2>{intro.heading}</h2>}
          <p>{intro.body}</p>
        </div>

        <div class="resume-cta__actions">
          <Button href="/resume">Open resume page</Button>
          <Button
            variant="secondary"
            href={resume.pdf.path}
            target="_blank"
            rel="noreferrer"
          >
            {resume.pdf.downloadLabel}
          </Button>
        </div>
      </section>
    </Container>
  </Section>

  {hasFeaturedProjects && leadProject && (
    <Section size="sm" aria-labelledby="home-projects-title">
      <Container size="wide">
        <SectionIntro
          title={featuredProjects.sectionTitle}
          titleId="home-projects-title"
          description={featuredProjects.sectionIntro}
          class="home-section-intro"
        />

        <div class="home-projects__lead">
          <ProjectCard
            {...leadProject}
            emphasis="lead"
            showPreview={false}
            primaryActionLabel="Read project blog"
          />
        </div>

        {hasSupportingProjects && (
          <div class="home-projects__supporting">
            <p class="home-supporting-label">Supporting systems</p>

            <Grid
              cols={supportingProjects.length > 1 ? '2' : 'auto'}
              gap="lg"
              minItemWidth="18rem"
            >
              {supportingProjects.map((item) => (
                <ProjectCard
                  {...item}
                  featured={false}
                  showPreview={false}
                  primaryActionLabel="Inspect supporting brief"
                />
              ))}
            </Grid>
          </div>
        )}
      </Container>
    </Section>
  )}

  {hasSelectedWriting && (
    <Section size="sm" tone="muted" aria-labelledby="home-writing-title">
      <Container size="wide">
        <SectionIntro
          title={selectedWriting.sectionTitle}
          titleId="home-writing-title"
          description={selectedWriting.sectionIntro}
          class="home-section-intro"
        />

        <Grid
          cols={visibleWritingGroups.length > 2 ? '3' : visibleWritingGroups.length > 1 ? '2' : 'auto'}
          gap="lg"
        >
          {visibleWritingGroups.map((group, index) => (
            <GroupedPanel
              title={group.label}
              titleId={`home-writing-group-${index}`}
              tone={group.tone}
              headingTag="h3"
            >
              <div class="writing-group__list">
                {group.items.map((item) => (
                  <WritingCard {...item} compact={true} />
                ))}
              </div>
            </GroupedPanel>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  {hasFeaturedTools && (
    <Section size="sm" aria-labelledby="home-tools-title">
      <Container size="wide">
        <SectionIntro
          title={featuredTools.sectionTitle}
          titleId="home-tools-title"
          description={featuredTools.sectionIntro}
          class="home-section-intro"
        />

        <Grid
          cols={featuredTools.items.length === 1 ? '2' : 'auto'}
          gap="lg"
          minItemWidth="18rem"
        >
          {featuredTools.items.map((item) => (
            <ToolCard
              {...item}
              showPreview={false}
              primaryActionLabel="Read tool blog"
            />
          ))}
        </Grid>
      </Container>
    </Section>
  )}
</SiteShell>
