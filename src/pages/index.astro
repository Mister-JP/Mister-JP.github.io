---
import SiteShell from '../layouts/SiteShell.astro';
import Button from '../components/ui/Button.astro';
import Container from '../components/ui/Container.astro';
import Grid from '../components/ui/Grid.astro';
import Prose from '../components/ui/Prose.astro';
import Section from '../components/ui/Section.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import GroupedPanel from '../components/ui/GroupedPanel.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ToolCard from '../components/tools/ToolCard.astro';
import WritingCard from '../components/writing/WritingCard.astro';
import { shellConfig } from '../data/site';
import { getHomePageContent } from '../lib/home-content';

const {
  page,
  hero,
  intro,
  featuredProjects,
  selectedWriting,
  featuredTools,
  resumeCta,
} = await getHomePageContent();

const hasFeaturedProjects = featuredProjects.items.length > 0;
const visibleWritingGroups = selectedWriting.groups
  .map((group, index) => ({
    ...group,
    tone: index === 1 ? 'soft' : 'default',
  }))
  .filter((group) => group.items.length > 0);
const hasSelectedWriting = visibleWritingGroups.length > 0;
const hasFeaturedTools = featuredTools.items.length > 0;
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <Section size="lg" class="home-hero" aria-labelledby="home-hero-title">
    <Container size="wide">
      <div class="hero-stack">
        <p class="hero-eyebrow">{hero.eyebrow}</p>
        <h1 id="home-hero-title" class="hero-title">{hero.title}</h1>
        <p class="hero-subtitle">{hero.subtitle}</p>
        <div class="hero-actions">
          <Button href={hero.primaryCtaHref}>{hero.primaryCtaLabel}</Button>
          <Button variant="secondary" href={hero.secondaryCtaHref}>
            {hero.secondaryCtaLabel}
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  <Section size="sm" aria-labelledby="home-intro-title">
    <Container size="narrow">
      <Prose class="intro-prose">
        <h2 id="home-intro-title">{intro.heading}</h2>
        <p>{intro.body}</p>
        {intro.supportingNote && <p class="intro-note">{intro.supportingNote}</p>}
      </Prose>
    </Container>
  </Section>

  {hasFeaturedProjects && (
    <Section aria-labelledby="home-projects-title">
      <Container size="wide">
        <SectionIntro
          title={featuredProjects.sectionTitle}
          titleId="home-projects-title"
          description={featuredProjects.sectionIntro}
        />

        <Grid
          cols={featuredProjects.items.length > 2 ? '3' : 'auto'}
          gap="lg"
          minItemWidth="18rem"
        >
          {featuredProjects.items.map((item) => (
            <ProjectCard {...item} />
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  {hasSelectedWriting && (
    <Section tone="muted" aria-labelledby="home-writing-title">
      <Container size="wide">
        <SectionIntro
          title={selectedWriting.sectionTitle}
          titleId="home-writing-title"
          description={selectedWriting.sectionIntro}
        />

        <Grid cols={visibleWritingGroups.length > 1 ? '2' : 'auto'} gap="lg">
          {visibleWritingGroups.map((group, index) => (
            <GroupedPanel
              title={group.label}
              titleId={`home-writing-group-${index}`}
              tone={group.tone}
              headingTag="h3"
            >
              <div class="writing-group__list">
                {group.items.map((item) => (
                  <WritingCard {...item} />
                ))}
              </div>
            </GroupedPanel>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  {hasFeaturedTools && (
    <Section aria-labelledby="home-tools-title">
      <Container size="wide">
        <SectionIntro
          title={featuredTools.sectionTitle}
          titleId="home-tools-title"
          description={featuredTools.sectionIntro}
        />

        <Grid gap="lg" minItemWidth="18rem">
          {featuredTools.items.map((item) => (
            <ToolCard {...item} />
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section tone="soft" aria-labelledby="home-resume-title">
    <Container size="wide">
      <div class="resume-cta">
        <div class="resume-cta__copy">
          <h2 id="home-resume-title">{resumeCta.heading}</h2>
          <p>{resumeCta.body}</p>
        </div>

        <div class="resume-cta__actions">
          <Button href={resumeCta.primaryCtaHref}>{resumeCta.primaryCtaLabel}</Button>
          <Button variant="secondary" href={resumeCta.secondaryCtaHref}>
            {resumeCta.secondaryCtaLabel}
          </Button>
        </div>
      </div>
    </Container>
  </Section>
</SiteShell>
