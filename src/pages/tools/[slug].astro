---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ToolDetailTemplate from '../../components/tools/ToolDetailTemplate.astro';
import { shellConfig } from '../../data/site';
import {
  getProjectHref,
  getWritingHref,
} from '../../lib/content-paths';
import { getToolFeatureImage } from '../../lib/feature-images';
import {
  getRelatedProjectsForEntry,
  getWritingEntriesForProjectSet,
} from '../../lib/content-relations';
import { getWritingCategoryLabel } from '../../lib/writing-categories';
import SiteShell from '../../layouts/SiteShell.astro';

type ToolEntry = CollectionEntry<'tools'>;

export async function getStaticPaths() {
  const tools = await getCollection('tools');

  const seenSlugs = new Set<string>();
  const paths: Array<{ params: { slug: string }; props: { tool: ToolEntry } }> = [];

  const registerPath = (slug: string, tool: ToolEntry) => {
    if (seenSlugs.has(slug)) {
      throw new Error(`Duplicate tool route slug "${slug}" detected in tools collection.`);
    }

    seenSlugs.add(slug);
    paths.push({
      params: { slug },
      props: { tool },
    });
  };

  tools.forEach((tool) => {
    registerPath(tool.slug, tool);
    tool.data.aliases
      .filter((alias) => alias !== tool.slug)
      .forEach((alias) => registerPath(alias, tool));
  });

  return paths;
}

const { tool } = Astro.props as { tool: ToolEntry };

const relatedProjects = await getRelatedProjectsForEntry(tool);
const relatedWritingEntries = await getWritingEntriesForProjectSet(relatedProjects);
const { Content, headings } = await tool.render();
const hasBody = Boolean(tool.body?.trim());

const links = [
  tool.data.links.open ? { label: 'Launch tool', href: tool.data.links.open } : undefined,
  tool.data.links.code ? { label: 'View source code', href: tool.data.links.code } : undefined,
]
  .filter(
    (action): action is { label: string; href: string } => Boolean(action?.href),
  )
  .map((action) => ({
    ...action,
    isExternal: action.href.startsWith('http'),
  }));
---

<SiteShell
  {...shellConfig}
  title={`${tool.data.title} | Tools | Jignasu Pathak`}
  description={tool.data.summary}
>
  <ToolDetailTemplate
    title={tool.data.title}
    summary={tool.data.summary}
    status={tool.data.status}
    tags={tool.data.tags}
    featureImage={getToolFeatureImage(tool.data.featureImage)}
    links={links}
    relatedProjects={relatedProjects.map((project) => ({
      title: project.data.title,
      summary: project.data.summary,
      status: project.data.status,
      href: getProjectHref(project),
    }))}
    relatedWriting={relatedWritingEntries.map((entry) => ({
      title: entry.data.title,
      summary: entry.data.summary,
      in_draft: entry.data.in_draft,
      categoryLabel: getWritingCategoryLabel(entry.data.category),
      href: getWritingHref(entry),
      tags: entry.data.tags,
    }))}
    headings={headings}
  >
    {hasBody && <Content />}
  </ToolDetailTemplate>
</SiteShell>
