---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import SiteShell from '../layouts/SiteShell.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Grid from '../components/ui/Grid.astro';
import Tag from '../components/ui/Tag.astro';
import GroupedPanel from '../components/ui/GroupedPanel.astro';
import WritingCard from '../components/writing/WritingCard.astro';
import { getProjectHref, getWritingHref } from '../lib/content-paths';
import { sortCollectionEntriesBySortOrderThenTitle } from '../lib/collection-utils';
import { getRelatedProjectsForEntry } from '../lib/content-relations';
import { shellConfig } from '../data/site';

type WritingEntry = CollectionEntry<'writing'>;

const buildWritingCards = async (
  entries: WritingEntry[],
) =>
  Promise.all(
    entries.map(async (entry) => {
      const relatedProjects = await getRelatedProjectsForEntry(entry);

      return {
        entry,
        href: getWritingHref(entry),
        relatedProjects: relatedProjects.map((project) => ({
          href: getProjectHref(project),
          title: project.data.title,
        })),
      };
    }),
  );

const [pageEntry, caseStudyEntries, methodEntries] = await Promise.all([
  getEntry('pages', 'writing'),
  getCollection('writing', ({ data }) => data.kind === 'case-study'),
  getCollection('writing', ({ data }) => data.kind === 'method'),
]);

if (!pageEntry) {
  throw new Error('Missing content entry: src/content/pages/writing.md');
}

if (pageEntry.data.template !== 'writing') {
  throw new Error('The writing page entry must use the "writing" template.');
}

const [caseStudies, methods] = await Promise.all([
  buildWritingCards(caseStudyEntries.sort(sortCollectionEntriesBySortOrderThenTitle)),
  buildWritingCards(methodEntries.sort(sortCollectionEntriesBySortOrderThenTitle)),
]);

const page = pageEntry.data;
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <PageHeader
    eyebrow={page.eyebrow}
    title={page.title}
    description={page.description}
  >
    <Tag slot="meta" tone="accent">{caseStudies.length} case studies</Tag>
    <Tag slot="meta">{methods.length} methods</Tag>
  </PageHeader>

  <Section size="sm">
    <Container size="wide">
      <Grid cols="2" gap="lg">
        <GroupedPanel
          title={page.caseStudies.title}
          titleId="case-studies-title"
          intro={page.caseStudies.intro}
        >
          <div class="writing-group__list">
            {caseStudies.length > 0 ? (
              caseStudies.map(({ entry, href, relatedProjects }) => (
                <WritingCard
                  {...entry.data}
                  href={href}
                  relatedProjects={relatedProjects}
                />
              ))
            ) : (
              <p class="writing-group__empty">{page.caseStudies.emptyState}</p>
            )}
          </div>
        </GroupedPanel>

        <GroupedPanel
          title={page.methods.title}
          titleId="methods-title"
          intro={page.methods.intro}
          tone="soft"
        >
          <div class="writing-group__list">
            {methods.length > 0 ? (
              methods.map(({ entry, href, relatedProjects }) => (
                <WritingCard
                  {...entry.data}
                  href={href}
                  relatedProjects={relatedProjects}
                />
              ))
            ) : (
              <p class="writing-group__empty">{page.methods.emptyState}</p>
            )}
          </div>
        </GroupedPanel>
      </Grid>
    </Container>
  </Section>
</SiteShell>
