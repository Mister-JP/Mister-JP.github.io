---
import { getCollection, getEntry } from 'astro:content';
import SiteShell from '../layouts/SiteShell.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Grid from '../components/ui/Grid.astro';
import Tag from '../components/ui/Tag.astro';
import GroupedPanel from '../components/ui/GroupedPanel.astro';
import WritingCard from '../components/writing/WritingCard.astro';
import { sortCollectionEntriesBySortOrderThenTitle } from '../lib/collection-utils';
import { getProjectHref, getWritingHref } from '../lib/content-paths';
import { shellConfig } from '../data/site';

const writing = (await getCollection('writing')).sort(
  sortCollectionEntriesBySortOrderThenTitle,
);

const writingCards = await Promise.all(
  writing.map(async (entry) => {
    const relatedProject = entry.data.relatedProject
      ? await getEntry(entry.data.relatedProject)
      : undefined;

    return {
      entry,
      href: getWritingHref(entry),
      relatedProjectHref: relatedProject ? getProjectHref(relatedProject) : undefined,
      relatedProjectTitle: relatedProject?.data.title,
    };
  }),
);

const caseStudies = writingCards.filter(
  ({ entry }) => entry.data.kind === 'case-study',
);
const methods = writingCards.filter(({ entry }) => entry.data.kind === 'method');
---

<SiteShell
  {...shellConfig}
  title="Writing | Jignasu Pathak"
  description="Content-driven writing index with separate case study and method groupings."
>
  <PageHeader
    eyebrow="Thinking"
    title="Writing"
    description="Writing remains grouped by meaning rather than becoming one undifferentiated stream, and every entry now comes from structured content."
  >
    <Tag slot="meta" tone="accent">{caseStudies.length} case studies</Tag>
    <Tag slot="meta">{methods.length} methods</Tag>
  </PageHeader>

  <Section size="sm">
    <Container size="wide">
      <Grid cols="2" gap="lg">
        <GroupedPanel
          title="Case Studies"
          titleId="case-studies-title"
          intro="Project-linked narratives that capture decisions, tradeoffs, and lessons learned."
        >
          <div class="writing-group__list">
            {caseStudies.length > 0 ? (
              caseStudies.map(({ entry, href, relatedProjectHref, relatedProjectTitle }) => (
                <WritingCard
                  {...entry.data}
                  href={href}
                  relatedProjectHref={relatedProjectHref}
                  relatedProjectTitle={relatedProjectTitle}
                />
              ))
            ) : (
              <p class="writing-group__empty">Case studies will appear here as entries are added.</p>
            )}
          </div>
        </GroupedPanel>

        <GroupedPanel
          title="Methods"
          titleId="methods-title"
          intro="Reusable engineering patterns that apply across projects and experiments."
          tone="soft"
        >
          <div class="writing-group__list">
            {methods.length > 0 ? (
              methods.map(({ entry, href, relatedProjectHref, relatedProjectTitle }) => (
                <WritingCard
                  {...entry.data}
                  href={href}
                  relatedProjectHref={relatedProjectHref}
                  relatedProjectTitle={relatedProjectTitle}
                />
              ))
            ) : (
              <p class="writing-group__empty">Methods will appear here as entries are added.</p>
            )}
          </div>
        </GroupedPanel>
      </Grid>
    </Container>
  </Section>
</SiteShell>

<style>
  .writing-group__list {
    display: grid;
    gap: var(--space-4);
  }

  .writing-group__empty {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: var(--line-relaxed);
  }
</style>
