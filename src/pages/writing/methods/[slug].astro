---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import WritingDetailTemplate from '../../../components/writing/WritingDetailTemplate.astro';
import { shellConfig } from '../../../data/site';
import { getWritingDetailPageData } from '../../../lib/writing-detail';
import SiteShell from '../../../layouts/SiteShell.astro';

type WritingEntry = CollectionEntry<'writing'>;

export async function getStaticPaths() {
  const methods = await getCollection('writing', ({ data }) => data.kind === 'method');

  return methods.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: WritingEntry };
const { Content, hasBody, templateProps } = await getWritingDetailPageData(entry);
---

<SiteShell
  {...shellConfig}
  title={`${entry.data.title} | Methods | Jignasu Pathak`}
  description={entry.data.summary}
>
  <WritingDetailTemplate {...templateProps}>
    {hasBody && <Content />}
  </WritingDetailTemplate>
</SiteShell>
