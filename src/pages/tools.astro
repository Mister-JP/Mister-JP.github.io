---
import { getCollection, getEntry } from 'astro:content';
import SiteShell from '../layouts/SiteShell.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Grid from '../components/ui/Grid.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import Tag from '../components/ui/Tag.astro';
import ToolCard from '../components/tools/ToolCard.astro';
import { sortCollectionEntriesBySortOrderThenTitle } from '../lib/collection-utils';
import { getToolHref } from '../lib/content-paths';
import { shellConfig } from '../data/site';

const tools = (await getCollection('tools')).sort(
  sortCollectionEntriesBySortOrderThenTitle,
);

const pageEntry = await getEntry('pages', 'tools');

if (!pageEntry) {
  throw new Error('Missing content entry: src/content/pages/tools.md');
}

if (pageEntry.data.template !== 'tools') {
  throw new Error('The tools page entry must use the "tools" template.');
}

const page = pageEntry.data;
const toolGridCols = tools.length > 2 ? '3' : tools.length > 1 ? '2' : 'auto';
---

<SiteShell
  {...shellConfig}
  title={`${page.title} | Jignasu Pathak`}
  description={page.description}
>
  <PageHeader
    eyebrow={page.eyebrow}
    title={page.title}
    description={page.description}
  >
    <Tag slot="meta" tone="accent">{tools.length} tools</Tag>
  </PageHeader>

  <Section size="sm" aria-labelledby="all-tools-title">
    <Container size="wide">
      <SectionIntro
        title={page.library.title}
        titleId="all-tools-title"
        description={page.library.intro}
      />

      <Grid cols={toolGridCols} minItemWidth="18rem">
        {tools.length > 0 ? (
          tools.map((tool) => (
            <ToolCard {...tool.data} detailHref={getToolHref(tool)} />
          ))
        ) : (
          <p class="tools-empty">{page.library.emptyState}</p>
        )}
      </Grid>
    </Container>
  </Section>
</SiteShell>

<style>
  .tools-empty {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: var(--line-relaxed);
  }
</style>
